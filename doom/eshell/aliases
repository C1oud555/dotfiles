alias q exit
alias ls exa $*
alias la exa -a $*
alias ll exa -lah $*
alias l exa -lh $*
alias tree  exa --tree $*
alias f find-file $1
alias ff find-file-other-window $1
alias d dired $1
alias bd eshell-up $1
alias rg rg --color=always $*
alias git git --no-pager $*
alias gg magit-status
alias cdp cd-to-project
alias clear clear-scrollback
